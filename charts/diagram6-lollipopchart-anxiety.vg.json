{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 500,
  "height": 300,
  "title": {
    "text": "Anxiety Disorder Subtypes by Sex",
    "subtitle": "Percentage of Australians with a 12-month anxiety disorder, 2020-2022",
    "fontSize": 16,
    "subtitleFontSize": 12
  },
  "data": {
    "url": "https://raw.githubusercontent.com/yoshanaaariaduray/FIT2179-DV2/refs/heads/main/anxiety.csv"
  },
  "transform": [
    {
      "fold": ["Male", "Female"],
      "as": ["Sex", "Rate"]
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "rule",
        "strokeWidth": 2
      },
      "encoding": {
        "y": {
          "field": "Anxiety disorders",
          "type": "nominal",
          "sort": "-x",
          "title": null
        },
        "x": {
          "aggregate": "min",
          "field": "Rate",
          "type": "quantitative",
          "title": "% with anxiety disorder"
        },
        "x2": {
          "aggregate": "max",
          "field": "Rate"
        },
        "color": {"value": "#cccccc"}
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 100
      },
      "encoding": {
        "y": {
          "field": "Anxiety disorders",
          "type": "nominal",
          "sort": "-x",
          "title": null
        },
        "x": {
          "field": "Rate",
          "type": "quantitative"
        },
        "color": {
          "field": "Sex",
          "type": "nominal",
          "scale": {
            "domain": ["Male", "Female"],
            "range": ["#4A90D9", "#E8738A"]
          },
          "legend": {"title": "Sex"}
        },
        "tooltip": [
          {"field": "Anxiety disorders", "type": "nominal", "title": "Disorder"},
          {"field": "Sex", "type": "nominal", "title": "Sex"},
          {"field": "Rate", "type": "quantitative", "title": "Rate (%)"}
        ]
      }
    }
  ]
}