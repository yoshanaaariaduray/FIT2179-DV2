{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 500,
  "height": 200,
  "title": {
    "text": "Mental Disorder Rates by Age Group and Disorder Type",
    "subtitle": "Percentage of Australians with a 12-month mental disorder, 2020-2022",
    "fontSize": 16,
    "subtitleFontSize": 12
  },
  "data": {
    "url": "https://raw.githubusercontent.com/yoshanaaariaduray/FIT2179-DV2/refs/heads/main/mental_health_age_sex_disorder.csv"
  },
  "transform": [
    {
      "fold": ["Any Anxiety disorders ", "Any Affective disorders", "Any Substance Use disorders"],
      "as": ["Disorder", "Rate"]
    }
  ],
  "mark": "rect",
  "encoding": {
    "x": {
      "field": "Age Group",
      "type": "nominal",
      "title": "Age Group",
      "axis": {"labelAngle": 0}
    },
    "y": {
      "field": "Disorder",
      "type": "nominal",
      "title": null
    },
    "color": {
      "field": "Rate",
      "type": "quantitative",
      "scale": {"scheme": "blues"},
      "legend": {"title": "Rate (%)"}
    },
    "tooltip": [
      {"field": "Age Group", "type": "nominal", "title": "Age Group"},
      {"field": "Disorder", "type": "nominal", "title": "Disorder"},
      {"field": "Rate", "type": "quantitative", "title": "Rate (%)"}
    ]
  }
}