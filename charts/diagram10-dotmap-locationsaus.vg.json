{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 600,
  "height": 400,
  "title": {
    "text": "Headspace Mental Health Service Locations Across Australia",
    "subtitle": "Youth mental health services are heavily concentrated in major cities",
    "fontSize": 16,
    "subtitleFontSize": 12
  },
  "projection": {"type": "mercator"},
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/rowanhogan/australian-states/master/states.geojson",
        "format": {"property": "features"}
      },
      "mark": {
        "type": "geoshape",
        "fill": "#f0f0f0",
        "stroke": "#cccccc",
        "strokeWidth": 1
      }
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/yoshanaaariaduray/FIT2179-DV2/refs/heads/main/headspace.csv"
      },
      "mark": {
        "type": "circle",
        "opacity": 0.8,
        "stroke": "white",
        "strokeWidth": 0.5
      },
      "encoding": {
        "longitude": {
          "field": "Long",
          "type": "quantitative"
        },
        "latitude": {
          "field": "Lat",
          "type": "quantitative"
        },
        "size": {"value": 60},
        "color": {
          "field": "State",
          "type": "nominal",
          "scale": {"scheme": "category10"},
          "legend": {"title": "State"}
        },
        "tooltip": [
          {"field": "Name", "type": "nominal", "title": "Centre"},
          {"field": "State", "type": "nominal", "title": "State"}
        ]
      }
    }
  ]
}