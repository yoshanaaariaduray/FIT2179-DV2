{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 600,
  "height": 400,
  "title": {
    "text": "Mental Health Spending Per Person Across Australia",
    "subtitle": "Constant price recurrent expenditure per capita 2023-24. ACT and national data not available.",
    "fontSize": 16,
    "subtitleFontSize": 12
  },
  "projection": {"type": "mercator"},
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/rowanhogan/australian-states/master/states.geojson",
        "format": {"property": "features"}
      },
      "mark": {
        "type": "geoshape",
        "fill": "#e0e0e0",
        "stroke": "white",
        "strokeWidth": 1
      }
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/rowanhogan/australian-states/master/states.geojson",
        "format": {"property": "features"}
      },
      "transform": [
        {
          "lookup": "properties.STATE_NAME",
          "from": {
            "data": {
              "url": "https://raw.githubusercontent.com/yoshanaaariaduray/FIT2179-DV2/refs/heads/main/spending_per_person_bystate_diagram12.csv"
            },
            "key": "State",
            "fields": ["Spending_Per_Capita"]
          }
        },
        {
          "filter": "datum.Spending_Per_Capita != null"
        }
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "white",
        "strokeWidth": 1
      },
      "encoding": {
        "color": {
          "field": "Spending_Per_Capita",
          "type": "quantitative",
          "scale": {
            "scheme": "greens",
            "domain": [250, 450]
          },
          "legend": {"title": "Spending per person ($)"}
        },
        "tooltip": [
          {"field": "properties.STATE_NAME", "type": "nominal", "title": "State"},
          {"field": "Spending_Per_Capita", "type": "quantitative", "title": "Spending per person ($)"}
        ]
      }
    }
  ]
}